{
    "name": "touhou-translations",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "homepage": "https://aenigmatrices.github.io/touhou-translations/",
    "description": "A viewer for English-translated Touhou Project fan comics and illustrations built with SvelteKit",
    "repository": {
        "type": "git",
        "url": "https://github.com/AEnigmatrices/touhou-translations.git"
    },
    "license": "MIT",
    "author": "AEnigmatrices",
    "scripts": {
        "dev": "vite dev --mode development",
        "build": "vite build --mode production && tsx scripts/generateSitemap.ts",
        "validate:data": "tsx scripts/validateData.ts",
        "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint .",
        "test": "pnpm run validate:data && pnpm run typecheck && pnpm run lint",
        "preview": "vite preview",
        "deploy": "gh-pages -d build --repo https://x-access-token:${GITHUB_TOKEN}@github.com/AEnigmatrices/touhou-translations.git"
    },
    "dependencies": {
        "@sveltejs/adapter-static": "3.0.10",
        "@sveltejs/kit": "2.65.0",
        "@sveltejs/vite-plugin-svelte": "7.1.2",
        "embla-carousel-svelte": "8.6.0",
        "marked": "18.0.5",
        "svelte": "5.56.3"
    },
    "devDependencies": {
        "@types/node": "25.9.3",
        "eslint": "10.4.1",
        "gh-pages": "6.3.0",
        "glob": "13.0.6",
        "globals": "17.6.0",
        "svelte-check": "4.6.0",
        "tsx": "4.22.4",
        "typescript": "6.0.3",
        "typescript-eslint": "8.61.0",
        "vite": "8.0.16"
    },
    "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
