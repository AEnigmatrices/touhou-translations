{
    "name": "touhou-translations",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "homepage": "https://aenigmatrices.github.io/touhou-translations/",
    "description": "A viewer for English-translated Touhou Project fan comics and illustrations built with React and Vite",
    "repository": {
        "type": "git",
        "url": "https://github.com/AEnigmatrices/touhou-translations.git"
    },
    "license": "MIT",
    "author": "AEnigmatrices",
    "scripts": {
        "dev": "vike dev --mode development",
        "build": "vike build --mode production",
        "typecheck": "tsc -b",
        "lint": "tsc -b --pretty false",
        "test": "pnpm run typecheck",
        "preview": "vike preview",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d dist --repo https://x-access-token:${GITHUB_TOKEN}@github.com/AEnigmatrices/touhou-translations.git"
    },
    "dependencies": {
        "@emotion/cache": "^11.14.0",
        "@emotion/react": "^11.14.0",
        "@emotion/server": "^11.11.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.0.1",
        "@mui/material": "^9.0.1",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-hook-form": "7.77.0",
        "react-image": "^4.1.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "swiper": "12.2.0",
        "vike": "^0.4.259",
        "vike-react": "0.6.23"
    },
    "devDependencies": {
        "@types/node": "25.9.1",
        "@types/react": "19.2.16",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "gh-pages": "^6.3.0",
        "glob": "^13.0.6",
        "globals": "^17.6.0",
        "tsx": "4.22.4",
        "typescript": "^6.0.3",
        "vite": "8.0.16",
        "vite-plugin-pwa": "^1.3.0"
    },
    "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
