{
    "name": "touhou-translations",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "homepage": "https://aenigmatrices.github.io/touhou-translations/",
    "description": "A viewer for English-translated Touhou Project fan comics and illustrations built with SvelteKit",
    "repository": {
        "type": "git",
        "url": "https://github.com/AEnigmatrices/touhou-translations.git"
    },
    "license": "MIT",
    "author": "AEnigmatrices",
    "scripts": {
        "clean": "tsx scripts/clean.ts",
        "generate:data": "tsx scripts/generateDerivedData.ts",
        "dev": "pnpm run generate:data && vite dev --mode development",
        "build": "pnpm run generate:data && vite build --mode production && tsx scripts/generateSitemap.ts",
        "validate:data": "tsx scripts/validateData.ts",
        "typecheck": "pnpm run generate:data && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint .",
        "test:unit": "pnpm run generate:data && vitest run",
        "test:unit:watch": "vitest",
        "test": "pnpm run validate:data && pnpm run typecheck && pnpm run lint && pnpm run test:unit",
        "preview": "vite preview",
        "deploy": "gh-pages -d build --repo https://x-access-token:${GITHUB_TOKEN}@github.com/AEnigmatrices/touhou-translations.git"
    },
    "dependencies": {
        "@sveltejs/adapter-static": "3.0.10",
        "@sveltejs/kit": "2.65.1",
        "@sveltejs/vite-plugin-svelte": "7.1.2",
        "marked": "18.0.5",
        "svelte": "5.56.3"
    },
    "devDependencies": {
        "@types/node": "25.9.3",
        "eslint": "10.5.0",
        "gh-pages": "6.3.0",
        "glob": "13.0.6",
        "globals": "17.6.0",
        "svelte-check": "4.6.0",
        "tsx": "4.22.4",
        "typescript": "6.0.3",
        "typescript-eslint": "8.61.0",
        "vite": "8.0.16",
        "vitest": "^4.1.8"
    },
    "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
